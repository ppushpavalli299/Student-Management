<mvc:View
    controllerName="webapp.student.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m">

    <Page id="pageDashboard" title="Dashboard">
        <content>

            <VBox id="_IDGenVBox1" class="sapUiSmallMargin">
                <Title id="_IDGenTitle" text="Overview" class="sapUiSmallMarginBottom"/>

                <!-- Horizontal container -->
                <HBox id="_IDGenHBox" class="sapUiSmallMargin"   wrap="Wrap" justifyContent="Start" alignItems="Start"gap="1rem">
                    <!-- Tile 1: Students -->
                    <GenericTile id="_IDGenGenericTile"
                        header="Total Students"
                        subheader="All registered students"
                        press="onStudentsTilePress">

                        <tileContent>
                            <TileContent id="_IDGenTileContent">
                                <content>
                                    <NumericContent id="_IDGenNumericContent"
                                        value="0"
                                        icon="sap-icon://group"
                                        valueColor="Good"/>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                    <!-- Tile 2: Courses -->
                    <GenericTile id="_IDGenGenericTile2"
                        header="Total Courses"
                        subheader="All available courses"
                        press="onCourseTilePress">

                        <tileContent>
                            <TileContent id="_IDGenTileContent1">
                                <content>
                                    <NumericContent id="_IDGenNumericContent1"
                                        value="0"
                                        icon="sap-icon://learning-course"
                                        valueColor="Good"/>
                                </content>
                            </TileContent>
                        </tileContent>
                    </GenericTile>

                </HBox>
            </VBox>

        </content>
    </Page>
</mvc:View>