{
  "_version": "1.83.0",
  "sap.app": {
    "id": "webapp.student",
    "type": "application",
    "i18n": "student/i18n/i18n.properties",
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/StudentService/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {},
        "sap.f": {}
      }
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleUrl": "student/i18n/i18n.properties"
        }
      },
      "": {
        "dataSource": "mainService",
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      }
    },
    "routing": {
      "routes": [
        {
          "pattern": ":?query:",
          "name": "StudentsList",
          "target": "StudentsList"
        },
        {
          "pattern": "Students({key}):?query:",
          "name": "StudentsObjectPage",
          "target": "StudentsObjectPage"
        }
      ],
      "targets": {
        "StudentsList": {
          "type": "Component",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/Students",
              "variantManagement": "Page",
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          },
          "id": "StudentsList"
        },
        "StudentsObjectPage": {
          "type": "Component",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "contextPath": "/Students",
              "editableHeaderContent": false
            }
          },
          "id": "StudentsObjectPage"
        }
      }
    },
    "extends": {
      "extensions": {
        "sap.ui.controllerExtensions": {
          "sap.suite.ui.generic.template.ListReport.view.ListReport": {
            "controllerName": "student.webapp.ext.UploadExcel"
          }
        }
      }
    },
    "sap.ui.viewExtensions": {
      "sap.fe.templates.ListReport.ListReport": {
        "TableToolbarExtension": {
          "className": "sap.ui.core.Fragment",
          "fragmentName": "webapp.student.ext.fragment.Toolbar",
          "type": "XML"
        }
      }
    }
  }
}
