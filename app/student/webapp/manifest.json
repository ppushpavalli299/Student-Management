{
  "_version": "1.83.0",
  "sap.app": {
    "id": "webapp.student",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/StudentService/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
"sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.146.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true
        }
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "webapp.student.i18n.i18n"
        }
      }
    },
    "routing": {
      "config": {
        "routerClass": "sap.m.routing.Router",
        "viewType": "XML",
        "viewPath": "webapp.student.view",
        "controlId": "appContent",
        "controlAggregation": "pages",
        "async": true
      },
      "routes": [
        {
          "pattern": "",
          "name": "Dashboard",
          "target": "Dashboard"
        },
        {
          "pattern": "students",
          "name": "StudentsList",
          "target": "StudentsList"
        },
        {
          "pattern": "Students({key})",
          "name": "StudentsObjectPage",
          "target": "StudentsObjectPage"
        },
        {
          "pattern": "totalCourses",
          "name": "StudentsTotalCoursesPage",
          "target": "StudentsTotalCoursesPage"
        }
      ],
      "targets": {
        "Dashboard": {
          "type": "View",
          "id": "Dashboard",
           "name": "webapp.student.view.Dashboard"
        },
          "StudentsList": {
          "type": "Component",
          "id": "StudentsList",
          "name": "sap.fe.templates.ListReport",
          "controlAggregation": "pages",
          "options": {
            "settings": {
              "contextPath": "/Students",
              "variantManagement": "Page",
              "navigation": {
                "Students": {
                  "detail": {
                    "route": "StudentsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable"
                  }
                }
              }
            }
          }
        },
        "StudentsObjectPage": {
          "type": "Component",
          "id": "StudentsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "controlAggregation": "pages",
          "options": {
            "settings": {
              "contextPath": "/Students"
            }
          }
        },
        "StudentsTotalCoursesPage": {
          "type": "View",
          "id": "StudentsTotalCoursesPage",
          "name": "webapp.student.ext.view.TotalCourses"
        }
      }
    }
  },
  "extends": {
    "extensions": {
      "sap.ui.controllerExtensions": {
        "sap.fe.templates.ListReport": {
          "controllerName": "webapp.student.ext.UploadExcel"
        }
      }
    }
  },
  "sap.ui.viewExtensions": {
    "sap.fe.templates.ListReport.ListReport": {
      "TableToolbarExtension": {
        "className": "sap.ui.core.Fragment",
        "fragmentName": "webapp.student.ext.fragment.Toolbar",
        "type": "XML"
      }
    }
  }
}
