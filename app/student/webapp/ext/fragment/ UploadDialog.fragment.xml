<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified">

    <Dialog id="uploadDialog" title="Upload Excel">
        <content>
            <VBox id="_IDGenVBox" class="sapUiSmallMargin">

                <u:FileUploader
                    id="fileUploader"
                    width="100%"
                    placeholder="Choose file..."
                    change="onFileChange"
                    fileType="xlsx,xls" />

                <Label id="_IDGenLabel" text="File Name:" class="sapUiSmallMarginTop"/>
                <Input id="fileNameInput" width="100%"/>

            </VBox>
        </content>

        <beginButton>
            <Button id="_IDGenButton" text="Upload" type="Emphasized" press="onUploadExcel"/>
        </beginButton>

        <endButton>
            <Button id="_IDGenButton1" text="Cancel" press="onCloseUploadDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>